NEXT_PUBLIC_LOTTERY_ADDRESS_MAINNET=

# Public community links
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/
NEXT_PUBLIC_TELEGRAM_INVITE_URL=https://t.me/
NEXT_PUBLIC_APP_URL=https://example.com
