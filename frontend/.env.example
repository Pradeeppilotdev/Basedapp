# WalletConnect Project ID
# Get yours at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional frontend RPC overrides
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
