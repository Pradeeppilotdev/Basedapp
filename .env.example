# Base Network RPC URLs
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# BaseScan API Key for contract verification
# Get your key from https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# Private key for deployment (NEVER commit the actual .env file!)
# This should be a dedicated deployment wallet, not your main wallet
PRIVATE_KEY=your_private_key_here

# Contract addresses (fill in after deployment)
LOTTERY_CONTRACT_ADDRESS_SEPOLIA=
LOTTERY_CONTRACT_ADDRESS_MAINNET=
